# ── Copy this to .env and fill in values ──
# Never commit .env to git

# ── Ollama ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=phi4-mini
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── MongoDB ──
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=elixara

# ── Redis ──
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600

# ── ChromaDB ──
CHROMA_DIR=./data/chroma_db

# ── Service URLs (used for inter-service calls) ──
INGEST_SERVICE_URL=http://localhost:5001
RAG_SERVICE_URL=http://localhost:5002
GRAPH_SERVICE_URL=http://localhost:5003
COMPLIANCE_SERVICE_URL=http://localhost:5004

# ── Paths ──
UPLOAD_DIR=./data/uploads
PARSED_DIR=./data/parsed

# ── Chunking ──
CHUNK_SIZE=400
CHUNK_OVERLAP=100

# ── Retrieval ──
DENSE_TOP_K=20
SPARSE_TOP_K=20
RRF_K=60
RERANK_TOP_K=5

# ── Auth ──
JWT_SECRET=elixara_hackathon_secret_change_this
JWT_EXPIRY=24h

# ── Frontend ──
FRONTEND_URL=http://localhost:5173
VITE_API_BASE=http://localhost:4000

# ── Gateway ──
GATEWAY_PORT=4000